<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER" spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.asimov.client.controllers.LoginController" stylesheets="@../css/styles.css">
    <padding>
        <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
    </padding>

    <VBox alignment="CENTER" spacing="20.0" styleClass="content-pane" maxWidth="400">
        <padding>
            <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
        </padding>
        <Label text="Asimov - Connexion" styleClass="title-label" />

        <VBox spacing="10.0" maxWidth="300">
            <Label text="Adresse Email" styleClass="subtitle-label" style="-fx-font-size: 14px;" />
            <TextField fx:id="emailInput" promptText="nom@college-asimov.fr" />

            <Label text="Mot de passe" styleClass="subtitle-label" style="-fx-font-size: 14px;" />
            <PasswordField fx:id="passwordInput" promptText="••••••••" />

            <Label fx:id="errorLabel" text="Identifiants incorrects" textFill="#dc2626" visible="false" wrapText="true" style="-fx-font-weight: bold; -fx-padding: 5 0 0 0;" />
        </VBox>

        <Button fx:id="loginButton" text="Se connecter" styleClass="button-primary" prefWidth="300" onAction="#handleLoginAction" />
    </VBox>
</VBox>