<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootVBox" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.asimov.client.controllers.DashboardController" stylesheets="@../css/styles.css">

    <HBox styleClass="top-bar" alignment="CENTER_LEFT" spacing="20.0">
        <Label text="Asimov" styleClass="title-label" style="-fx-padding: 0; -fx-text-fill: #1E88E5;" />

        <HBox spacing="5.0" HBox.hgrow="ALWAYS">
            <Button fx:id="elevesNavButton" text="Élèves" styleClass="nav-button, nav-button-active" onAction="#showElevesTab" />
            <Button fx:id="optionsNavButton" text="Options" styleClass="nav-button" onAction="#showOptionsTab" />
        </HBox>

        <Label fx:id="welcomeLabel" style="-fx-text-fill: #9E9E9E;" text="Bienvenue !" />
        <Button text="Déconnexion" styleClass="button, button-danger" onAction="#handleLogout" />
    </HBox>

    <VBox spacing="20.0" VBox.vgrow="ALWAYS" style="-fx-padding: 20px;">
        <HBox fx:id="headerBox" alignment="CENTER_LEFT" spacing="15.0">
            <Label fx:id="pageTitleLabel" text="Gestion des Élèves" styleClass="subtitle-label" />
            <Region HBox.hgrow="ALWAYS" />
            <TextField fx:id="searchField" promptText="Rechercher..." prefWidth="250" />
        </HBox>

        <VBox styleClass="content-pane" VBox.vgrow="ALWAYS" spacing="15.0">

            <VBox fx:id="gestionElevesBox" VBox.vgrow="ALWAYS" spacing="15.0">
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <Button fx:id="addEleveButton" text="Nouveau" styleClass="button-primary" onAction="#handleAddEleve" />
                    <Button fx:id="editEleveButton" text="Modifier" styleClass="button" onAction="#handleEditEleve" disable="true" />
                    <Button fx:id="deleteEleveButton" text="Supprimer" styleClass="button, button-danger" onAction="#handleDeleteEleve" disable="true" />
                </HBox>

                <TableView fx:id="elevesTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="idColumn" text="ID" prefWidth="60.0" />
                        <TableColumn fx:id="nomColumn" text="Nom" prefWidth="200.0" />
                        <TableColumn fx:id="prenomColumn" text="Prénom" prefWidth="200.0" />
                        <TableColumn fx:id="emailColumn" text="Email" prefWidth="300.0" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <VBox fx:id="gestionOptionsBox" VBox.vgrow="ALWAYS" spacing="15.0" visible="false" managed="false">
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <TextField fx:id="newOptionField" promptText="Nom de la nouvelle option..." prefWidth="250" />
                    <Button text="Créer l'option" styleClass="button-primary" onAction="#handleAddOption" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Button fx:id="deleteOptionButton" text="Supprimer l'option" styleClass="button, button-danger" onAction="#handleDeleteOption" disable="true" />
                </HBox>

                <TableView fx:id="optionsTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                    <columns>
                        <TableColumn fx:id="optionIdColumn" text="ID" prefWidth="80.0" />
                        <TableColumn fx:id="optionNomColumn" text="Nom de l'option" prefWidth="400.0" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <VBox fx:id="profilEleveBox" alignment="CENTER" spacing="25.0" visible="false" managed="false" VBox.vgrow="ALWAYS">
                <Label text="Mon Profil" styleClass="title-label" style="-fx-font-size: 32px;" />

                <VBox alignment="CENTER" spacing="5.0">
                    <Label fx:id="profilNomLabel" style="-fx-font-weight: bold; -fx-font-size: 24px;" text="Nom Prénom" />
                    <Label fx:id="profilEmailLabel" style="-fx-text-fill: #9E9E9E; -fx-font-size: 16px;" text="email@college.fr" />
                </VBox>

                <VBox alignment="CENTER" spacing="15.0" style="-fx-background-color: #242424; -fx-padding: 25; -fx-background-radius: 8; -fx-border-color: #383838; -fx-border-radius: 8; -fx-min-width: 300; -fx-max-width: 400;">
                    <Label text="Mes Options Choisies" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1E88E5;" />
                    <Label fx:id="profilOptionsLabel" text="Chargement en cours..." style="-fx-font-size: 16px; -fx-text-fill: #E0E0E0;" textAlignment="CENTER" wrapText="true" />
                </VBox>
            </VBox>

        </VBox>
    </VBox>
</VBox>