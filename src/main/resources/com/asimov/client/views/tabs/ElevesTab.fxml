<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.asimov.client.controllers.ElevesTabController" spacing="15.0" style="-fx-background-color: transparent; -fx-padding: 0;">

    <HBox alignment="CENTER_LEFT" spacing="15.0">
        <Label text="Gestion des Élèves" styleClass="subtitle-label" />
        <Region HBox.hgrow="ALWAYS" />

        <Button fx:id="addEleveButton" text="Nouveau" styleClass="button-primary" onAction="#handleAddEleve" />

        <Button fx:id="editEleveButton" text="Modifier" styleClass="button" onAction="#handleEditEleve" disable="true" />
        <Button fx:id="deleteEleveButton" text="Supprimer" styleClass="button, button-danger" onAction="#handleDeleteEleve" disable="true" />
    </HBox>

    <TableView fx:id="elevesTable" VBox.vgrow="ALWAYS" styleClass="table-view">
        <columns>
            <TableColumn fx:id="idColumn" text="ID" prefWidth="60.0" />
            <TableColumn fx:id="nomColumn" text="Nom" prefWidth="200.0" />
            <TableColumn fx:id="prenomColumn" text="Prénom" prefWidth="200.0" />
            <TableColumn fx:id="emailColumn" text="Email" prefWidth="300.0" />
        </columns>
        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
    </TableView>

    <HBox spacing="15.0" alignment="CENTER" style="-fx-padding: 10 0 0 0;">
        <Button fx:id="prevPageButton" text="Précédent" onAction="#handlePrevPage" styleClass="button" />

        <Label fx:id="paginationLabel" text="Page 1 sur 1" styleClass="subtitle-label" />

        <Button fx:id="nextPageButton" text="Suivant" onAction="#handleNextPage" styleClass="button" />
    </HBox>
</VBox>