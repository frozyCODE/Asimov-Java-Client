<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="15.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.asimov.client.controllers.OptionsTabController">
    <HBox spacing="10.0" alignment="CENTER_LEFT">
        <TextField fx:id="newOptionField" promptText="Nom de l'option..." prefWidth="250" />
        <Button text="Créer l'option" styleClass="button-primary" onAction="#handleAddOption" />
        <Region HBox.hgrow="ALWAYS" />
        <Button fx:id="deleteOptionButton" text="Supprimer" styleClass="button, button-danger" onAction="#handleDeleteOption" disable="true" />
    </HBox>
    <TableView fx:id="optionsTable" VBox.vgrow="ALWAYS" styleClass="table-view">
        <columns>
            <TableColumn fx:id="optionIdColumn" text="ID" prefWidth="80.0" />
            <TableColumn fx:id="optionNomColumn" text="Nom de l'option" prefWidth="400.0" />
        </columns>
        <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
    </TableView>
</VBox>