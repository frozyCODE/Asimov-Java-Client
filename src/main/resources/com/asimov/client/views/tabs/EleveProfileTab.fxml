<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="25.0" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.asimov.client.controllers.EleveProfileTabController" styleClass="content-pane">

    <HBox spacing="20.0" alignment="CENTER_LEFT" style="-fx-background-color: #18181B; -fx-padding: 20; -fx-background-radius: 10; -fx-border-color: #27272A; -fx-border-radius: 10;">
        <VBox spacing="5.0">
            <Label fx:id="nomCompletLabel" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #FFFFFF;" text="Chargement..." />
            <Label fx:id="emailLabel" style="-fx-font-size: 16px; -fx-text-fill: #9CA3AF;" text="email@asimov.fr" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <VBox alignment="CENTER_RIGHT">
            <Label text="STATUT" style="-fx-text-fill: #3B82F6; -fx-font-weight: bold; -fx-font-size: 12px;" />
            <Label text="Élève Actif" style="-fx-text-fill: #FFFFFF; -fx-font-size: 14px;" />
        </VBox>
    </HBox>

    <HBox spacing="25.0" VBox.vgrow="ALWAYS">

        <VBox spacing="20.0" prefWidth="350.0">
            <VBox spacing="10.0" style="-fx-background-color: #18181B; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #27272A; -fx-border-radius: 10;">
                <Label text="CLASSE ACTUELLE" styleClass="subtitle-label" />
                <Label fx:id="classeLabel" style="-fx-font-size: 18px; -fx-text-fill: #FFFFFF;" text="Non affecté" />
            </VBox>

            <VBox spacing="10.0" style="-fx-background-color: #18181B; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #27272A; -fx-border-radius: 10;" VBox.vgrow="ALWAYS">
                <Label text="MES OPTIONS" styleClass="subtitle-label" />
                <ListView fx:id="optionsList" style="-fx-background-color: transparent; -fx-background-insets: 0; -fx-padding: 0;" prefHeight="150.0" />
            </VBox>
        </VBox>

        <VBox spacing="15.0" HBox.hgrow="ALWAYS" style="-fx-background-color: #18181B; -fx-padding: 15; -fx-background-radius: 10; -fx-border-color: #27272A; -fx-border-radius: 10;">
            <Label text="MES RÉSULTATS SEMESTRIELS" styleClass="subtitle-label" />
            <TableView fx:id="moyennesTable" VBox.vgrow="ALWAYS" styleClass="table-view">
                <columns>
                    <TableColumn fx:id="semestreColumn" text="Semestre" prefWidth="120.0" />
                    <TableColumn fx:id="moyenneColumn" text="Moyenne" prefWidth="120.0" />
                    <TableColumn fx:id="statutColumn" text="Décision Proviseur" prefWidth="200.0" />
                </columns>
                <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
            </TableView>
        </VBox>
    </HBox>
</VBox>