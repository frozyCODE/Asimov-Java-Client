<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.asimov.client.controllers.MoyennesTabController" spacing="15.0" style="-fx-background-color: transparent; -fx-padding: 0;">

    <Label text="Gestion des Moyennes" styleClass="subtitle-label" />

    <HBox spacing="15.0" alignment="CENTER_LEFT">
        <ComboBox fx:id="eleveMoyenneCombo" promptText="1. Choisir un élève..." prefWidth="250.0" />
        <ComboBox fx:id="inscriptionMoyenneCombo" promptText="2. Année scolaire..." prefWidth="200.0" disable="true" />
    </HBox>

    <TableView fx:id="moyennesTable" VBox.vgrow="ALWAYS" styleClass="table-view">
        <columns>
            <TableColumn fx:id="semestreColumn" text="Semestre" prefWidth="100.0" />
            <TableColumn fx:id="moyenneColumn" text="Moyenne Générale" prefWidth="150.0" />
            <TableColumn fx:id="statutColumn" text="Statut" prefWidth="150.0" />
        </columns>
        <columnResizePolicy>
            <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
        </columnResizePolicy>
    </TableView>

    <VBox fx:id="actionMoyenneBox" spacing="10.0">
        <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0; -fx-border-color: #2A2A2A transparent transparent transparent; -fx-border-width: 1 0 0 0;">
            <TextField fx:id="newMoyenneField" promptText="Ex: 14.5" prefWidth="100.0" disable="true" />
            <ComboBox fx:id="semestreAddCombo" prefWidth="120.0" promptText="Semestre" disable="true" />
            <Button fx:id="saisirNoteButton" text="Saisir la note" styleClass="button-primary" onAction="#handleAddMoyenne" disable="true" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="deleteMoyenneButton" text="Supprimer" styleClass="button, button-danger" onAction="#handleDeleteMoyenne" disable="true" />
            <Button fx:id="validerMoyenneButton" text="Valider la moyenne" styleClass="button" onAction="#handleValiderMoyenne" disable="true" />
        </HBox>
    </VBox>
</VBox>