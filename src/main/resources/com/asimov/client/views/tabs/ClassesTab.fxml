<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<SplitPane fx:id="gestionClassesBox" orientation="VERTICAL" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.asimov.client.controllers.ClassesTabController" style="-fx-background-color: transparent; -fx-padding: 0;">

    <VBox spacing="15.0" style="-fx-padding: 0 0 10 0;">
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <Label text="Nouvelle :" styleClass="label" />
            <ComboBox fx:id="newClasseAnneeCombo" promptText="Année Scolaire" prefWidth="150" />
            <ComboBox fx:id="newClasseNiveauCombo" promptText="Niveau" prefWidth="100" />
            <TextField fx:id="newClasseLettreField" promptText="Lettre (ex: A)" prefWidth="100" />
            <Button text="Créer la classe" styleClass="button-primary" onAction="#handleAddClasse" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="deleteClasseButton" text="Supprimer la classe" styleClass="button, button-danger" onAction="#handleDeleteClasse" disable="true" />
        </HBox>
        <TableView fx:id="classesTable" VBox.vgrow="ALWAYS" styleClass="table-view">
            <columns>
                <TableColumn fx:id="classeIdColumn" text="ID" prefWidth="60.0" />
                <TableColumn fx:id="classeAnneeColumn" text="Année Scolaire" prefWidth="200.0" />
                <TableColumn fx:id="classeNiveauColumn" text="Niveau" prefWidth="150.0" />
                <TableColumn fx:id="classeLettreColumn" text="Lettre" prefWidth="150.0" />
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
        </TableView>
    </VBox>

    <VBox spacing="15.0" style="-fx-padding: 10 0 0 0;">
        <Label fx:id="titreTrombinoscopeLabel" text="Élèves inscrits" styleClass="subtitle-label" />
        <HBox spacing="10.0" alignment="CENTER_LEFT">
            <ComboBox fx:id="eleveToEnrollCombo" promptText="Sélectionner un élève à ajouter..." prefWidth="250.0" disable="true" />
            <Button fx:id="inscrireEleveButton" text="Inscrire dans cette classe" styleClass="button-primary" onAction="#handleInscrireEleve" disable="true" />
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="retirerEleveButton" text="Retirer de la classe" styleClass="button" onAction="#handleRetirerEleve" disable="true" />
        </HBox>
        <TableView fx:id="elevesInscritsTable" VBox.vgrow="ALWAYS" styleClass="table-view" disable="true">
            <columns>
                <TableColumn fx:id="inscNomColumn" text="Nom" prefWidth="200.0" />
                <TableColumn fx:id="inscPrenomColumn" text="Prénom" prefWidth="200.0" />
                <TableColumn fx:id="inscEmailColumn" text="Email" prefWidth="300.0" />
            </columns>
            <columnResizePolicy><TableView fx:constant="CONSTRAINED_RESIZE_POLICY" /></columnResizePolicy>
        </TableView>
    </VBox>
</SplitPane>